# Domus — environment (never commit real secrets)

# Required in production for correct canonicals / OG / sitemap
NEXT_PUBLIC_SITE_URL=https://domuswindows.com

# Required in production — lead POST fails closed (503) if unset
# Must be https:// … (Zapier / Make / n8n / Slack incoming webhook, etc.)
LEAD_WEBHOOK_URL=

# Optional durable rate limit (Upstash Redis REST). Without these, in-memory RL is used (not multi-instance safe).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: set to "1" to discourage indexing while using placeholder photography
# NEXT_PUBLIC_NOINDEX=1
